[flake8]
max-line-length = 120
exclude =
    .venv,
    venv,
    venv_old_backup,
    .venv_old_backup,
    __pycache__,
    .git,
    migrations

# Per-file temporary ignores so we can iterate. Remove/slowly fix these files later.
per-file-ignores =
    video_builder.py: E501,E302,E305,F811,F401,F824,E231,E225,E712,E722
    auto_short_full.py: E501,E231
    short_maker.py: E501,E231,F401,E722
    sheets_logger.py: E501,E231